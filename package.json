{
  "name": "neondojo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome lint ./src --skip-parse-errors",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ./src --skip-parse-errors",
    "check": "biome check ./src --skip-parse-errors",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.52",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.2",
    "ai": "^6.0.134",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "simple-git-hooks": {
    "pre-push": "bun run check"
  }
}
